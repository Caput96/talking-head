# Copy to .env.local (gitignored) to override. All vars are optional.

# Which TTS provider the app uses:
#   browser (default) — Kokoro in-browser, zero setup, no server needed.
#   server            — ServerTTSProvider → local /server over HTTP.
#                       Requires the server running: `pnpm dev:server`
#                       (or `pnpm dev:all` to run web + server together).
VITE_TTS_PROVIDER=browser

# Base URL of the local server (only used when VITE_TTS_PROVIDER=server).
VITE_TTS_SERVER_URL=http://localhost:8000
